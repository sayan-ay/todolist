<form class="container mt-4" action="/add" method="POST">

    <div class="mb-3">
        <label class="form-label fw-bold text-dark">Task</label>
        <input type="text" class="form-control" name="task" placeholder="Enter task name">
    </div>

    <div class="mb-3">
        <label class="form-label  fw-bold text-dark">Time</label>
        <input type="text" class="form-control" name="time" placeholder="Enter time">
    </div>

    <div class="mb-3">
        <label class="form-label  fw-bold text-dark">Description</label>
        <input type="text" class="form-control" name="description" placeholder="Enter description">
    </div>

    <button type="submit" class="btn btn-success">Add Task</button>

</form>